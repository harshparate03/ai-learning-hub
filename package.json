    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/router": "^18.2.0",
    "@swimlane/ngx-graph": "^12.0.0-alpha.0",
    "bootstrap": "^5.3.8",
    "d3": "^7.9.0",
    "docx": "^9.6.1",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.6.205",
    "pptxgenjs": "^4.0.1",
