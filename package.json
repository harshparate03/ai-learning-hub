{
  "name": "ai-learning-hub",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "node scripts/start-with-proxy.js",
    "start:app": "node scripts/sync-local-env.js && ng serve",
    "dev": "node scripts/start-with-proxy.js",
    "proxy": "node --use-system-ca api-proxy.js",
    "build": "ng build --configuration production",
    "build:dev": "ng build --configuration development",
